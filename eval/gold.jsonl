# Retrieval eval gold set (retrieval contract §8.1).  JSONL — one query per line; '#' lines ignored.
# Schema: {"id","query","category","judgments":{card_id: 0..3},"caller"?,"mode"?,"rigor"?,"note"?}
#   category ∈ lookup_fact | lookup_definition | relation | change | multi_hop | out_of_graph
#   judgments grade the CARD IDs the KB can return: 3=directly answers, 2=partially, 1=related, 0=irrelevant
#   out_of_graph queries need NO judgments — their gold is "system returns Tier 3/4".
#
# HOW TO GRADE (the maintainer's ~2h one-time pass):
#   1. run:  python -m knowledgehost eval --trace          (baseline; prints per-query top card ids)
#   2. for each in-graph query, copy the returned card ids into "judgments" with a 0..3 grade.
#      (or use  python -m knowledgehost ask "<query>"  and read the ids.)
#   3. the out_of_graph rows below already work with no grading — they measure abstention today.
# Target: ≥60 to proceed, 100+ ideal, ~15% out_of_graph, spread across the categories.
#
# ── out-of-graph (unanswerable here → gold = Tier 3/4; usable immediately, no grading) ──
{"id": "oog01", "query": "what is the wifi password in the office", "category": "out_of_graph", "note": "personal/local — not in a reference KB"}
{"id": "oog02", "query": "who won eurovision in 2019", "category": "out_of_graph", "note": "episodic trivia, out of scope"}
{"id": "oog03", "query": "help me get over my breakup", "category": "out_of_graph", "note": "personal/relational — belongs to the personal graph, not here"}
{"id": "oog04", "query": "what did I have for breakfast yesterday", "category": "out_of_graph", "note": "episodic/personal"}
{"id": "oog05", "query": "translate 'good morning' into Klingon", "category": "out_of_graph", "note": "not in corpus"}
#
# ── in-graph templates (FILL judgments after a baseline run — empty judgments = inactive) ──
{"id": "fact01", "query": "management of post-spinal hypotension in caesarean section", "category": "lookup_fact", "judgments": {}, "context_features": {"trigger": "spinal anaesthesia", "context": "caesarean section", "sign": "hypotension"}, "note": "FILL: grade the returned card ids"}
{"id": "fact02", "query": "first-line vasopressor for hypotension after spinal anaesthesia", "category": "lookup_fact", "judgments": {}, "note": "FILL"}
{"id": "def01", "query": "what is left uterine displacement", "category": "lookup_definition", "judgments": {}, "note": "FILL"}
